# ── Base de datos (misma Turso que el bot, u otra) ──
TURSO_DATABASE_URL=      # libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=

# ── Login del carnicero (PWA) ──
PEDIDOS_PIN=             # PIN numérico para entrar desde la tablet (ej: 1234)
PEDIDOS_SESSION_SECRET=  # string random largo para firmar la sesión (ej: openssl rand -hex 32)

# ── Token del bot para crear pedidos (POST /api/pedidos) ──
PEDIDOS_API_TOKEN=       # string random largo; el bot lo manda como Authorization: Bearer <token>

# ── Opcional ──
# NEGOCIO_TZ=America/Argentina/Buenos_Aires   # zona horaria para "fuera de horario" (default: Argentina)
