# ── Anthropic ──
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp Cloud API (Meta) ──
WHATSAPP_TOKEN=          # token de acceso (empezá con el temporal, después uno permanente)
PHONE_NUMBER_ID=         # Phone Number ID del número de prueba/producción
VERIFY_TOKEN=            # una palabra secreta que vos inventás (la misma que ponés en Meta)

# ── Opcional ──
# OWNER_PHONE=549381...  # tu número, para recibir avisos cuando el bot deriva

# ── Base de datos (historial + backoffice) ──
TURSO_DATABASE_URL=      # libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=

# ── Backoffice (/backoffice.html) ──
BACKOFFICE_SESSION_SECRET=      # string random largo, para firmar la sesión (ej: openssl rand -hex 32)
# Los agentes (usuario + contraseña) NO son una env var: se crean con
#   node scripts/crear-agente.mjs <usuario> <password> ["Nombre"]
