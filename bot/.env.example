# ── LLM por OpenRouter ──
OPENROUTER_API_KEY=
MODEL_ROUTER=google/gemini-2.5-flash-lite
MODEL_EXPERTO=anthropic/claude-sonnet-4.6

# ── WhatsApp Cloud API (Meta) ──
WHATSAPP_TOKEN=          # token de acceso (empezá con el temporal, después uno permanente)
PHONE_NUMBER_ID=         # Phone Number ID del número de prueba/producción
VERIFY_TOKEN=            # una palabra secreta que vos inventás (la misma que ponés en Meta)
META_GRAPH_VERSION=      # versión habilitada en la app Meta, ej. v25.0

# ── Opcional ──
# OWNER_PHONE=549381...  # tu número, para recibir avisos cuando el bot deriva

# ── CRM central (historial + atención humana) ──
CRM_API_URL=             # URL del deploy crm/, ej. https://crm-tuempresa.vercel.app
CRM_API_KEY=             # wbk_... generada una sola vez desde el panel superadmin

# ── Catálogo y pedidos comerciales de Tobías ──
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
