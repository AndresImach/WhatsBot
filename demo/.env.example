# ── LLM (vía OpenRouter — openrouter.ai) ──
OPENROUTER_API_KEY=sk-or-v1-...
# Opcional: pivotear de modelo/proveedor sin tocar código. Slugs de OpenRouter,
# ej "anthropic/claude-haiku-4.5", "openai/gpt-4o-mini", "google/gemini-2.5-flash-lite".
# Si dejás estas vacías, usa los defaults en api/chat.js.
MODEL_BARATO=
MODEL_EXPERTO=
MODEL_ROUTER=

# ── Tobías (catálogo/pedidos reales, base de ESE cliente) ──
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Sola Jones (negocio ?n=solajones) → catálogo en vivo desde WooCommerce ──
# REST API de WooCommerce, clave de SOLO LECTURA
# (WooCommerce → Ajustes → Avanzado → REST API → Añadir clave, permiso: Lectura).
SOLAJONES_WOO_URL=https://solajones.com
SOLAJONES_WOO_CK=ck_...
SOLAJONES_WOO_CS=cs_...

# ── Carnicería (negocio ?n=carniceria) → PWA de mostrador (carpeta pedidos/) ──
# El bot lee el catálogo y registra pedidos en la PWA por HTTP (no toca Turso acá).
PEDIDOS_API_URL=         # URL del deploy de la PWA, ej: https://tu-pedidos.vercel.app
PEDIDOS_API_TOKEN=       # el mismo PEDIDOS_API_TOKEN que configuraste en la PWA

# ── Registro de conversaciones del demo + pivot a humano (base APARTE, no la de Tobías) ──
LOG_TURSO_DATABASE_URL=
LOG_TURSO_AUTH_TOKEN=
# Correr una vez contra esa base: turso db shell <tu-base-de-logs> < schema.sql

# (Opcional) protege /api/logs y resumen.html con ?key=<LOG_TOKEN>
LOG_TOKEN=

# ── Backoffice (/backoffice.html) — atender a mano las conversaciones derivadas ──
BACKOFFICE_PASSWORD=
BACKOFFICE_SESSION_SECRET=      # string random largo, ej: openssl rand -hex 32
