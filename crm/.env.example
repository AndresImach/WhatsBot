# Base Turso central (whatsbot-demo-logs)
CRM_TURSO_DATABASE_URL=
CRM_TURSO_AUTH_TOKEN=

# Sesiones del backoffice (openssl rand -hex 32)
CRM_SESSION_SECRET=

# Exactamente 32 bytes en base64 (openssl rand -base64 32)
CRM_CRYPTO_KEY=

# Versión habilitada en la app Meta del WABA, por ejemplo v25.0
META_GRAPH_VERSION=

# Solo para scripts de migración de un bot legacy
SOURCE_TURSO_DATABASE_URL=
SOURCE_TURSO_AUTH_TOKEN=
